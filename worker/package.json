{
  "name": "portfolio-analytics",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create portfolio-analytics-db",
    "db:migrate": "wrangler d1 execute portfolio-analytics-db --file=schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute portfolio-analytics-db --file=schema.sql --local"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "wrangler": "^3.99.0"
  }
}
